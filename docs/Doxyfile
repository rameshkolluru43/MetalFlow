# Doxyfile for MetalFlow
PROJECT_NAME           = "MetalFlow"
PROJECT_NUMBER         = "1.0"
PROJECT_BRIEF          = "CUDA-style Metal layer for CFD/FEA on Apple Silicon"
OUTPUT_DIRECTORY       = .
CREATE_SUBDIRS         = NO

INPUT                  = ../include \
                         ../src \
                         ../examples \
                         ../shaders \
                         mainpage.md \
                         architecture.md \
                         laplace_solver.md
FILE_PATTERNS          = *.hpp *.h *.cpp *.mm *.metal *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/*

USE_MDFILE_AS_MAINPAGE = mainpage.md
MARKDOWN_SUPPORT       = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT

HAVE_DOT               = YES
DOT_PATH               = /opt/homebrew/bin
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 3

USE_MATHJAX            = YES
MATHJAX_VERSION        = MathJax_3
MATHJAX_FORMAT         = SVG

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
VERBATIM_HEADERS       = YES

WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
QUIET                  = NO

EXTENSION_MAPPING      = metal=C++ mm=C++

ALPHABETICAL_INDEX     = YES
SORT_BRIEF_DOCS        = YES
SHOW_USED_FILES        = YES
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES

STRIP_FROM_PATH        = ../
STRIP_FROM_INC_PATH    = ../include
